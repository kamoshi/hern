type Tree('a) = Leaf('a) | Node((Tree('a), Tree('a)))

fn flatten(t) {
  match t {
    Leaf(x) -> [x],
    Node((left, right)) -> (left |> flatten) <> flatten(right),
  }
}

fn max_list(xs, fallback) {
  match xs {
    [] -> fallback,
    [x] -> x,
    [x, ..rest] -> max(x, max_list(rest, fallback)),
  }
}

fn flatten_alias(t) {
  let go = flatten_alias;
  match t {
    Leaf(x) -> [x],
    Node((left, right)) -> go(left) <> go(right),
  }
}

print(flatten(Node((Leaf(1), Leaf(2)))).len());
print(max_list([1, 5, 3], 0));
print(flatten_alias(Node((Leaf(1), Leaf(2)))).len());
