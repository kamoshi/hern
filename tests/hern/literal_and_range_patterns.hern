fn int_name(n: int) -> string {
  match n {
    -3..=-1 -> "negative",
    0 -> "zero",
    1..=3 -> "small",
    4..6 -> "middle",
    _ -> "other",
  }
}

fn bool_name(value: bool) -> string {
  match value {
    true -> "yes",
    false -> "no",
  }
}

fn float_name(n: float) -> string {
  match n {
    -1.5 -> "negative",
    0.0 -> "zero",
    _ -> "other",
  }
}

print(int_name(-2))
print(int_name(0))
print(int_name(2))
print(int_name(5))
print(int_name(6))
print(bool_name(true))
print(bool_name(false))
print(float_name(-1.5))
print(float_name(0.0))
print(float_name(1.5))
