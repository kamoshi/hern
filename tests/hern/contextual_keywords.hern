fn test(x: int) -> int {
  x
}

fn rec(x: int) -> int {
  x + 1
}

fn alias(x: int) -> int {
  x + 2
}

let test = test(5);
let rec = rec(test);
let alias = alias(rec);
let record = #{ test: test, rec: rec, alias: alias };

print(to_string(record.test));
print(to_string(record.rec));
print(to_string(record.alias));
