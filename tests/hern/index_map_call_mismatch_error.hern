fn reconstruct(came_from: Map('k, 'v), current, key) {
    let mut path = [current];
    let k = key(current);
    let xd = came_from[k];

    match xd {
        None -> (),
        Some(parent) -> path.push(parent),
    }
}

let mut came_from = Map::new();
came_from.set("next", "node");

reconstruct(came_from, "node", fn(value) { value });
