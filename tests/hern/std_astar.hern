let astar = import "hern:astar";

fn key(n: int) -> string {
  n.to_string()
}

fn neighbors(n: int) -> [int] {
  if n == 0 {
    [1, 3]
  } else if n == 1 {
    [0, 2, 4]
  } else if n == 2 {
    [1, 5]
  } else if n == 3 {
    [0, 4]
  } else if n == 4 {
    [1, 3, 5]
  } else if n == 5 {
    [2, 4]
  } else {
    []
  }
}

fn distance(a: int, b: int) -> float {
  1.0
}

fn heuristic(n: int) -> float {
  if n == 0 {
    3.0
  } else if n == 1 {
    2.0
  } else if n == 2 {
    1.0
  } else if n == 3 {
    2.0
  } else if n == 4 {
    1.0
  } else {
    0.0
  }
}

let path = astar.search(
  0,
  fn(n) { n == 5 },
  key,
  neighbors,
  distance,
  heuristic
);

print(json(path));

let no_path = astar.search(
  9,
  fn(n) { n == 5 },
  key,
  neighbors,
  distance,
  heuristic
);

print(json(no_path));
