// ── Sum types ─────────────────────────────────────────────────────────────────

fn unwrap_or(opt: Option('a), default: 'a) -> 'a {
    match opt {
        Some(v) -> v,
        None -> default,
    }
}

print(unwrap_or(Some(42), 0));
print(unwrap_or(None, 99));

// ── Record patterns ───────────────────────────────────────────────────────────

fn get_x(p: #{ x: int, y: int }) -> int {
    match p {
        #{ x, .. } -> x,
    }
}

fn swap_label(p: #{ x: int, y: int }) -> int {
    match p {
        #{ x: a, y: b } -> a + b,
    }
}

let point = #{ x: 3, y: 4 };
print(get_x(point));
print(swap_label(point));

fn first_field(r: #{ x: int, y: int }) -> int {
    match r {
        #{ x, ..rest } -> x,
    }
}

print(first_field(#{ x: 10, y: 20 }));

// ── List patterns ─────────────────────────────────────────────────────────────

fn list_head(xs: [int]) -> int {
    match xs {
        [] -> 0,
        [h, ..] -> h,
    }
}

fn list_sum(xs: [int]) -> int {
    match xs {
        [] -> 0,
        [h, ..rest] -> h + list_sum(rest),
    }
}

print(list_head([]));
print(list_head([5, 6, 7]));
print(list_sum([1, 2, 3, 4, 5]));

fn is_pair(xs: [int]) -> int {
    match xs {
        [_, _] -> 1,
        _ -> 0,
    }
}

print(is_pair([1, 2]));
print(is_pair([1, 2, 3]));
