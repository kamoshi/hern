type Wrap = Wrap(float)

fn twice(x: float) { x + x }

impl string {
  fn keep(self) { self }
}

impl float {
  fn double(self) { self + self }
}

impl Wrap {
  fn unwrap(self) {
    match self {
      Wrap(value) -> value,
    }
  }
}

let some = Some(1.0);
let none = None;
let n = 21.0;
let m = 5.0;
let wrapped = Wrap(34.0);

print(some.is_some());
print(none.is_some());
print(some.is_none());
print(none.is_none());
print(n.double());
print(wrapped.unwrap());
print(m.twice());
print("hello".keep());

let record = #{ twice: fn(x) { x + 1.0 } };
print(record.twice(9.0));
