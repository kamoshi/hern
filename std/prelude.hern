  exp: fn(float) -> float,
  floor: fn(float) -> float,
  fmod: fn(float, float) -> float,
  ldexp: fn(float, float) -> float,
  log: fn(float) -> float,
  log10: fn(float) -> float,
  max: fn(float, float) -> float,
  min: fn(float, float) -> float,
  pow: fn(float, float) -> float,
  rad: fn(float) -> float,
  random: fn() -> float,
  randomseed: fn(float) -> (),
  sin: fn(float) -> float,
  sinh: fn(float) -> float,
  sqrt: fn(float) -> float,
  tan: fn(float) -> float,
  tanh: fn(float) -> float,
