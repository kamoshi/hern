#![no_implicit_prelude]

// --- Core data ---

trait ToString 'a {
  fn to_string(self: 'a) -> string
}

fn to_string(value: 'a) -> string where 'a: ToString {
  ToString.to_string(value)
}

type Option('a) = Some('a) | None

impl Option('a) {
  fn is_some(self) -> bool {
    match self {
      Some(_) -> true,
      None -> false,
    }
  }

  fn is_none(self) -> bool {
    match self {
      Some(_) -> false,
      None -> true,
    }
  }

  fn unwrap_or(self, default: 'a) -> 'a {
    match self {
      Some(value) -> value,
      None -> default,
    }
  }

  fn map(self, f: fn('a) -> 'b) -> Option('b) {
    match self {
      Some(value) -> Some(f(value)),
      None -> None,
    }
  }

  fn and_then(self, f: fn('a) -> Option('b)) -> Option('b) {
    match self {
      Some(value) -> f(value),
      None -> None,
    }
  }
}

type Result('a, 'e) = Ok('a) | Err('e)

impl Result('a, 'e) {
  fn is_ok(self) -> bool {
    match self {
      Ok(_) -> true,
      Err(_) -> false,
    }
  }

  fn is_err(self) -> bool {
    match self {
      Ok(_) -> false,
      Err(_) -> true,
    }
  }

  fn unwrap_or(self, default: 'a) -> 'a {
    match self {
      Ok(value) -> value,
      Err(_) -> default,
    }
  }

  fn map(self, f: fn('a) -> 'b) -> Result('b, 'e) {
    match self {
      Ok(value) -> Ok(f(value)),
      Err(error) -> Err(error),
    }
  }

  fn map_err(self, f: fn('e) -> 'b) -> Result('a, 'b) {
    match self {
      Ok(value) -> Ok(value),
      Err(error) -> Err(f(error)),
    }
  }

  fn and_then(self, f: fn('a) -> Result('b, 'e)) -> Result('b, 'e) {
    match self {
      Ok(value) -> f(value),
      Err(error) -> Err(error),
    }
  }
}

impl ToString for Option('a)
where 'a: ToString
{
  fn to_string(self) {
    match self {
      Some(value) -> "Some(" <> ToString.to_string(value) <> ")",
      None -> "None",
    }
  }
}

impl ToString for Result('a, 'e)
where 'a: ToString, 'e: ToString
{
  fn to_string(self) {
    match self {
      Ok(value) -> "Ok(" <> ToString.to_string(value) <> ")",
      Err(error) -> "Err(" <> ToString.to_string(error) <> ")",
    }
  }
}

type Map('k, 'v) = *

type Heap('a) = *

// --- Primitive operators ---

extern __float_add: fn(float, float) -> float = #[template] "(($1) + ($2))";
extern __float_sub: fn(float, float) -> float = #[template] "(($1) - ($2))";
extern __float_mul: fn(float, float) -> float = #[template] "(($1) * ($2))";
extern __float_div: fn(float, float) -> float = #[template] "(($1) / ($2))";
extern __float_mod: fn(float, float) -> float = #[template] "(($1) % ($2))";

extern __int_add: fn(int, int) -> int = #[template] "bit.tobit(($1) + ($2))";
extern __int_sub: fn(int, int) -> int = #[template] "bit.tobit(($1) - ($2))";
extern __int_mul: fn(int, int) -> int = #[template] "bit.tobit(($1) * ($2))";
extern __int_div: fn(int, int) -> int = #[template] "bit.tobit(($1) / ($2))";
extern __int_mod: fn(int, int) -> int = #[template] "bit.tobit(($1) % ($2))";

extern __float_lt:  fn(float, float) -> bool = #[template] "((($1) < ($2)) and 1 or 0)";
extern __float_gt:  fn(float, float) -> bool = #[template] "((($1) > ($2)) and 1 or 0)";
extern __float_lte: fn(float, float) -> bool = #[template] "((($1) <= ($2)) and 1 or 0)";
extern __float_gte: fn(float, float) -> bool = #[template] "((($1) >= ($2)) and 1 or 0)";
extern __int_lt:  fn(int, int) -> bool = #[template] "((($1) < ($2)) and 1 or 0)";
extern __int_gt:  fn(int, int) -> bool = #[template] "((($1) > ($2)) and 1 or 0)";
extern __int_lte: fn(int, int) -> bool = #[template] "((($1) <= ($2)) and 1 or 0)";
extern __int_gte: fn(int, int) -> bool = #[template] "((($1) >= ($2)) and 1 or 0)";

extern __eq_float:  fn(float, float) -> bool = #[template] "((($1) == ($2)) and 1 or 0)";
extern __eq_int:  fn(int, int) -> bool = #[template] "((($1) == ($2)) and 1 or 0)";
extern __eq_string: fn(string, string) -> bool = #[template] "((($1) == ($2)) and 1 or 0)";
extern __eq_bool: fn(bool, bool) -> bool = #[template] "((($1) == ($2)) and 1 or 0)";
extern __neq_float: fn(float, float) -> bool = #[template] "((($1) ~= ($2)) and 1 or 0)";
extern __neq_int: fn(int, int) -> bool = #[template] "((($1) ~= ($2)) and 1 or 0)";
extern __neq_string: fn(string, string) -> bool = #[template] "((($1) ~= ($2)) and 1 or 0)";
extern __neq_bool: fn(bool, bool) -> bool = #[template] "((($1) ~= ($2)) and 1 or 0)";

extern __and: fn(bool, bool) -> bool = #[template] "((($1) ~= 0 and ($2) ~= 0) and 1 or 0)";
extern __or:  fn(bool, bool) -> bool = #[template] "((($1) ~= 0 or ($2) ~= 0) and 1 or 0)";

extern __concat: fn(string, string) -> string = #[template] "(($1) .. ($2))";

extern __int_to_float: fn(int) -> float = #[template] "($1)";
extern __float_trunc_to_int: fn(float) -> int = #[template] "bit.tobit(math.modf($1))";
extern __float_floor_to_int: fn(float) -> int = #[template] "bit.tobit(math.floor($1))";
extern __float_ceil_to_int: fn(float) -> int = #[template] "bit.tobit(math.ceil($1))";

trait Add 'a {
  fn infixl 6 +(lhs: 'a, rhs: 'a) -> 'a
}

trait Sub 'a {
  fn infixl 6 -(lhs: 'a, rhs: 'a) -> 'a
}

trait Mul 'a {
  fn infixl 7 *(lhs: 'a, rhs: 'a) -> 'a
}

trait Div 'a {
  fn infixl 7 /(lhs: 'a, rhs: 'a) -> 'a
}

trait Mod 'a {
  fn infixl 7 %(lhs: 'a, rhs: 'a) -> 'a
}

trait Ord 'a {
  fn infix 4 <(lhs: 'a, rhs: 'a) -> bool
  fn infix 4 >(lhs: 'a, rhs: 'a) -> bool
  fn infix 4 <=(lhs: 'a, rhs: 'a) -> bool
  fn infix 4 >=(lhs: 'a, rhs: 'a) -> bool
}

trait Eq 'a {
  fn infix 4 ==(lhs: 'a, rhs: 'a) -> bool
  fn infix 4 !=(lhs: 'a, rhs: 'a) -> bool
}

trait Semigroup 'a {
  fn infixr 5 <>(lhs: 'a, rhs: 'a) -> 'a
}

trait And 'a {
  fn infixl 3 &&(lhs: 'a, rhs: 'a) -> bool
}

trait Or 'a {
  fn infixl 2 ||(lhs: 'a, rhs: 'a) -> bool
}

impl Add for float {
  #[inline]
  fn +(lhs, rhs) { __float_add(lhs, rhs) }
}

impl Sub for float {
  #[inline]
  fn -(lhs, rhs) { __float_sub(lhs, rhs) }
}

impl Mul for float {
  #[inline]
  fn *(lhs, rhs) { __float_mul(lhs, rhs) }
}

impl Div for float {
  #[inline]
  fn /(lhs, rhs) { __float_div(lhs, rhs) }
}

impl Mod for float {
  #[inline]
  fn %(lhs, rhs) { __float_mod(lhs, rhs) }
}

impl Ord for float {
  #[inline]
  fn <(lhs, rhs) { __float_lt(lhs, rhs) }
  #[inline]
  fn >(lhs, rhs) { __float_gt(lhs, rhs) }
  #[inline]
  fn <=(lhs, rhs) { __float_lte(lhs, rhs) }
  #[inline]
  fn >=(lhs, rhs) { __float_gte(lhs, rhs) }
}

impl Eq for float {
  #[inline]
  fn ==(lhs, rhs) { __eq_float(lhs, rhs) }
  #[inline]
  fn !=(lhs, rhs) { __neq_float(lhs, rhs) }
}

impl float {
  fn trunc(self) -> int { __float_trunc_to_int(self) }
  fn floor(self) -> int { __float_floor_to_int(self) }
  fn ceil(self) -> int { __float_ceil_to_int(self) }
}

impl ToString for float {
  fn to_string(self) { tostring(self) }
}

impl Add for int {
  #[inline]
  fn +(lhs, rhs) { __int_add(lhs, rhs) }
}

impl Sub for int {
  #[inline]
  fn -(lhs, rhs) { __int_sub(lhs, rhs) }
}

impl Mul for int {
  #[inline]
  fn *(lhs, rhs) { __int_mul(lhs, rhs) }
}

impl Div for int {
  #[inline]
  fn /(lhs, rhs) { __int_div(lhs, rhs) }
}

impl Mod for int {
  #[inline]
  fn %(lhs, rhs) { __int_mod(lhs, rhs) }
}

impl Ord for int {
  #[inline]
  fn <(lhs, rhs) { __int_lt(lhs, rhs) }
  #[inline]
  fn >(lhs, rhs) { __int_gt(lhs, rhs) }
  #[inline]
  fn <=(lhs, rhs) { __int_lte(lhs, rhs) }
  #[inline]
  fn >=(lhs, rhs) { __int_gte(lhs, rhs) }
}

impl Eq for int {
  #[inline]
  fn ==(lhs, rhs) { __eq_int(lhs, rhs) }
  #[inline]
  fn !=(lhs, rhs) { __neq_int(lhs, rhs) }
}

impl int {
  fn to_float(self) -> float { __int_to_float(self) }
}

impl ToString for int {
  fn to_string(self) { tostring(self) }
}

impl Eq for string {
  #[inline]
  fn ==(lhs, rhs) { __eq_string(lhs, rhs) }
  #[inline]
  fn !=(lhs, rhs) { __neq_string(lhs, rhs) }
}

impl Eq for bool {
  #[inline]
  fn ==(lhs, rhs) { __eq_bool(lhs, rhs) }
  #[inline]
  fn !=(lhs, rhs) { __neq_bool(lhs, rhs) }
}

impl ToString for bool {
  fn to_string(self) {
    if self { "true" } else { "false" }
  }
}

impl And for bool {
  #[inline]
  fn &&(lhs, rhs) { __and(lhs, rhs) }
}

impl Or for bool {
  #[inline]
  fn ||(lhs, rhs) { __or(lhs, rhs) }
}

impl Semigroup for string {
  #[inline]
  fn <>(lhs, rhs) { __concat(lhs, rhs) }
}

impl ToString for string {
  fn to_string(self) { self }
}

// --- Globals ---

extern _unpack: fn(['a], int) -> ['a] = "table.unpack or unpack";

extern print: fn('a) -> () = "(function(x)
  if type(x) == \"table\" then
  local s = \"{\"
  for k, v in pairs(x) do s = s .. tostring(k) .. \"=\" .. tostring(v) .. \", \" end
  _G.print(s .. \"}\")
  else
  _G.print(x)
  end
  return {}
end)";

extern assert: fn(bool, string) -> () = "(function(c, m) if c == 0 then _G.error(m or \"assertion failed!\") end end)";
extern error: fn(string) -> ! = "error";
extern todo: fn(string) -> ! = "(function(message) _G.error(\"todo: \" .. (message or \"not implemented\")) end)";
extern tostring: fn('a) -> string = "tostring";
extern type_of: fn('a) -> string = "type";
extern collectgarbage: fn(string) -> float = "collectgarbage";

extern _VERSION: string = "_VERSION";

extern pcall: fn(fn() -> 'a) -> Result('a, string) = "(function(f)
  local ok, res = _G.pcall(f)
  if ok then return { _tag = \"Ok\", _0 = res } else return { _tag = \"Err\", _0 = _G.tostring(res) } end
end)";

extern rawequal: fn('a, 'a) -> bool = "(function(a, b) return _G.rawequal(a, b) and 1 or 0 end)";
extern rawget: fn(Map('k, 'v), 'k) -> 'v = "rawget";
extern rawset: fn(Map('k, 'v), 'k, 'v) -> () = "rawset";

// --- Arrays ---

extern __array_len: fn(['a]) -> int = #[template] "#($1)";
extern __array_get: fn(['a], int) -> 'a = #[template] "($1)[($2)]";
extern __array_set: fn(['a], int, 'a) -> () = "(function(a, i, v) a[i] = v; return {} end)";
extern __push: fn(['a], 'a) -> () = "(function(a, x) a[#a+1] = x; return {} end)";
extern __pop: fn(['a]) -> 'a = "(function(a) return table.remove(a) end)";

extern __array_map: fn(['a], fn('a) -> 'b) -> ['b] = "(function(a, f)
  local r = {}
  for i, v in ipairs(a) do r[i] = f(v) end
  return r
end)";
extern __array_filter: fn(['a], fn('a) -> bool) -> ['a] = "(function(a, f)
  local r = {}
  for _, v in ipairs(a) do if f(v) ~= 0 then r[#r+1] = v end end
  return r
end)";
extern __array_fold: fn(['a], 'b, fn('b, 'a) -> 'b) -> 'b = "(function(a, init, f)
  local acc = init
  for _, v in ipairs(a) do acc = f(acc, v) end
  return acc
end)";
extern __array_reverse: fn(['a]) -> ['a] = "(function(a)
  local r = {}
  for i = #a, 1, -1 do r[#r+1] = a[i] end
  return r
end)";
extern __array_concat: fn(['a], ['a]) -> ['a] = "(function(a, b)
  local r = {}
  for _, v in ipairs(a) do r[#r+1] = v end
  for _, v in ipairs(b) do r[#r+1] = v end
  return r
end)";
extern __array_range: fn(int, int) -> [int] = "(function(a, b)
  local r = {}
  for i = a, b do r[#r+1] = i end
  return r
end)";
extern __array_sum_float: fn([float]) -> float = "(function(a)
  local s = 0
  for _, v in ipairs(a) do s = s + v end
  return s
end)";
extern __array_sum_int: fn([int]) -> int = "(function(a)
  local s = 0
  for _, v in ipairs(a) do s = bit.tobit(s + v) end
  return s
end)";
extern __array_max: fn([float]) -> float = "(function(a)
  local m = -math.huge
  for _, v in ipairs(a) do if v > m then m = v end end
  return m
end)";
extern __array_min: fn([float]) -> float = "(function(a)
  local m = math.huge
  for _, v in ipairs(a) do if v < m then m = v end end
  return m
end)";

fn range(a: int, b: int) -> [int] { __array_range(a, b) }

impl ['a] {
  fn len(self) -> int {
    __array_len(self)
  }

  fn is_empty(self) -> bool {
    self.len() == 0
  }

  fn get(self, i: int) -> 'a {
    __array_get(self, i)
  }

  fn get_opt(self, i: int) -> Option('a) {
    if i >= 1 && i <= self.len() {
      Some(self.get(i))
    } else {
      None
    }
  }

  fn first(self) -> Option('a) {
    self.get_opt(1)
  }

  fn last(self) -> Option('a) {
    self.get_opt(self.len())
  }

  fn set(mut self, i: int, val: 'a) -> () {
    __array_set(self, i, val)
  }

  fn push(mut self, val: 'a) -> () {
    __push(self, val)
  }

  fn pop(mut self) -> 'a {
    __pop(self)
  }

  fn map(self, f: fn('a) -> 'b) -> ['b] {
    __array_map(self, f)
  }

  fn filter(self, f: fn('a) -> bool) -> ['a] {
    __array_filter(self, f)
  }

  fn fold(self, init: 'b, f: fn('b, 'a) -> 'b) -> 'b {
    __array_fold(self, init, f)
  }

  fn reverse(self) -> ['a] {
    __array_reverse(self)
  }

  fn any(self, f: fn('a) -> bool) -> bool {
    let mut found = false;
    for item in self {
      if f(item) {
        found = true;
        break;
      };
    };
    found
  }

  fn all(self, f: fn('a) -> bool) -> bool {
    let mut ok = true;
    for item in self {
      if !f(item) {
        ok = false;
        break;
      };
    };
    ok
  }

  fn find(self, f: fn('a) -> bool) -> Option('a) {
    let mut found = None;
    for item in self {
      if f(item) {
        found = Some(item);
        break;
      };
    };
    found
  }
}

impl ToString for ['a]
where 'a: ToString
{
  fn to_string(self) {
    let mut out = "[";
    let mut first = true;
    for item in self {
      if first {
        first = false;
      } else {
        out = out <> ", ";
      };
      out = out <> ToString.to_string(item);
    };
    out <> "]"
  }
}

impl [float] {
  fn sum(self) -> float {
    __array_sum_float(self)
  }

  fn max(self) -> float {
    __array_max(self)
  }

  fn min(self) -> float {
    __array_min(self)
  }
}

impl [int] {
  fn sum(self) -> int {
    __array_sum_int(self)
  }
}

impl Semigroup for ['a] {
  fn <>(lhs, rhs) { __array_concat(lhs, rhs) }
}

// --- Functional traits ---

trait Functor 'f {
  fn map(fa: 'f('a), f: fn('a) -> 'b) -> 'f('b)
}

impl Functor for Option {
  fn map(fa: Option('a), f: fn('a) -> 'b) -> Option('b) {
    fa.map(f)
  }
}

impl Functor for Array {
  fn map(fa: ['a], f: fn('a) -> 'b) -> ['b] {
    fa.map(f)
  }
}

// Result(*, 'e) maps over the Ok side, leaving the error type fixed.
impl Functor for Result(*, 'e) {
  fn map(fa: Result('a, 'e), f: fn('a) -> 'b) -> Result('b, 'e) {
    fa.map(f)
  }
}

trait Applicative 'f {
  fn pure(a: 'a) -> 'f('a)

  fn infixl 4 <*>(ff: 'f(fn('a) -> 'b), fa: 'f('a)) -> 'f('b)
}

impl Applicative for Option {
  fn pure(a: 'a) -> Option('a) { Some(a) }

  fn <*>(ff: Option(fn('a) -> 'b), fa: Option('a)) -> Option('b) {
    match ff {
      Some(f) -> fa.map(f),
      None -> None,
    }
  }
}

impl Applicative for Array {
  fn pure(a: 'a) -> ['a] { [a] }

  fn <*>(ff: [fn('a) -> 'b], fa: ['a]) -> ['b] {
    __array_fold(ff, [], fn(acc, f) { __array_concat(acc, __array_map(fa, f)) })
  }
}

impl Applicative for Result(*, 'e) {
  fn pure(a: 'a) -> Result('a, 'e) { Ok(a) }

  fn <*>(ff: Result(fn('a) -> 'b, 'e), fa: Result('a, 'e)) -> Result('b, 'e) {
    match ff {
      Ok(f) -> fa.map(f),
      Err(e) -> Err(e),
    }
  }
}

trait Monad 'f {
  fn infixl 1 >>=(fa: 'f('a), f: fn('a) -> 'f('b)) -> 'f('b)
}

impl Monad for Option {
  fn >>=(fa: Option('a), f: fn('a) -> Option('b)) -> Option('b) {
    fa.and_then(f)
  }
}

impl Monad for Array {
  fn >>=(fa: ['a], f: fn('a) -> ['b]) -> ['b] {
    __array_fold(fa, [], fn(acc, a) { __array_concat(acc, f(a)) })
  }
}

impl Monad for Result(*, 'e) {
  fn >>=(fa: Result('a, 'e), f: fn('a) -> Result('b, 'e)) -> Result('b, 'e) {
    fa.and_then(f)
  }
}

// --- Maps ---

extern __map_new: fn() -> mut Map('k, 'v) = "(function() return {} end)";
extern __map_set: fn(Map('k, 'v), 'k, 'v) -> () = "(function(m, k, v) m[k] = v; return {} end)";
extern __map_get: fn(Map('k, 'v), 'k) -> Option('v) = "(function(m, k) local v = m[k]; if v ~= nil then return { _tag = \"Some\", _0 = v } else return { _tag = \"None\" } end end)";
extern __map_delete: fn(Map('k, 'v), 'k) -> () = "(function(m, k) m[k] = nil; return {} end)";
extern __map_has: fn(Map('k, 'v), 'k) -> bool = "(function(m, k) return m[k] ~= nil and 1 or 0 end)";
extern __map_keys: fn(Map('k, 'v)) -> ['k] = "(function(m) local ks = {}; for k in pairs(m) do ks[#ks + 1] = k end; return ks end)";
extern __map_size: fn(Map('k, 'v)) -> int = "(function(m) local n = 0; for _ in pairs(m) do n = n + 1 end; return n end)";

impl Map('k, 'v) {
  fn new() -> mut Self { __map_new() }
  fn set(mut self, key: 'k, value: 'v) -> () { __map_set(self, key, value) }
  fn get(self, key: 'k) -> Option('v) { __map_get(self, key) }
  fn delete(mut self, key: 'k) -> () { __map_delete(self, key) }
  fn has(self, key: 'k) -> bool { __map_has(self, key) }
  fn keys(self) -> ['k] { __map_keys(self) }
  fn size(self) -> int { __map_size(self) }
  fn is_empty(self) -> bool { self.size() == 0 }
}

// --- Strings ---

extern __str_len: fn(string) -> int = #[template] "#($1)";
extern __char_at: fn(string, int) -> string = #[template] "($1):sub(($2),($2))";
extern __str_lines: fn(string) -> [string] = "(function(s)
  local r = {}
  s = s:gsub(\"\\r\\n\", \"\\n\")
  if s:sub(-1) == \"\\n\" then s = s:sub(1, -2) end
  for line in (s .. \"\\n\"):gmatch(\"([^\\n]*)\\n\") do r[#r+1] = line end
  return r
end)";
extern __str_words: fn(string) -> [string] = "(function(s)
  local r = {}
  for w in s:gmatch(\"%S+\") do r[#r+1] = w end
  return r
end)";
extern __str_split: fn(string, string) -> [string] = "(function(s, sep)
  local r, l, n = {}, 1, #sep
  while true do
  local f = s:find(sep, l, true)
  if not f then break end
  r[#r+1] = s:sub(l, f - 1)
  l = f + n
  end
  r[#r+1] = s:sub(l)
  return r
end)";
extern __str_chars: fn(string) -> [string] = "(function(s)
  local r = {}
  for c in s:gmatch(\".\") do r[#r+1] = c end
  return r
end)";
extern __str_trim: fn(string) -> string = "(function(s) return s:match(\"^%s*(.-)%s*$\") end)";
extern __str_contains: fn(string, string) -> bool =
  "(function(s, sub) return s:find(sub, 1, true) ~= nil and 1 or 0 end)";
extern __str_starts_with: fn(string, string) -> bool =
  "(function(s, p) return s:sub(1, #p) == p and 1 or 0 end)";
extern __str_ends_with: fn(string, string) -> bool =
  "(function(s, p) return #p == 0 or s:sub(-#p) == p and 1 or 0 end)";
extern __str_to_int: fn(string) -> int = "(function(s)
  local n = _G.tonumber(s)
  if not n or n ~= math.floor(n) then _G.error(\"int: cannot parse \" .. _G.tostring(s)) end
  return bit.tobit(n)
end)";
extern __str_to_float: fn(string) -> float = "(function(s)
  local n = _G.tonumber(s)
  if not n then _G.error(\"float: cannot parse \" .. _G.tostring(s)) end
  return n
end)";

impl string {
  fn len(self) -> int { __str_len(self) }
  fn is_empty(self) -> bool { self.len() == 0 }
  fn char_at(self, i: int) -> string { __char_at(self, i) }
  fn get(self, i: int) -> Option(string) {
    if i >= 1 && i <= self.len() {
      Some(self.char_at(i))
    } else {
      None
    }
  }
  fn lines(self) -> [string] { __str_lines(self) }
  fn words(self) -> [string] { __str_words(self) }
  fn split(self, sep: string) -> [string] { __str_split(self, sep) }
  fn chars(self) -> [string] { __str_chars(self) }
  fn trim(self) -> string { __str_trim(self) }
  fn contains(self, sub: string) -> bool { __str_contains(self, sub) }
  fn starts_with(self, prefix: string) -> bool { __str_starts_with(self, prefix) }
  fn ends_with(self, suffix: string) -> bool { __str_ends_with(self, suffix) }
  fn to_int(self) -> int { __str_to_int(self) }
  fn to_float(self) -> float { __str_to_float(self) }
}

// --- Iteration ---

trait Iterable 'f {
  fn iter(self: 'f('a)) -> Iter('a)
}

extern __array_iter: fn(['a]) -> Iter('a) = "(function(arr)
  local i = 0
  local n = #arr
  return function()
  i = i + 1
  if i <= n then return arr[i] else return nil end
  end
end)";

impl Iterable for Array {
  fn iter(self) { __array_iter(self) }
}

