}

extern jit: JitModule = "jit or {}";

extern getenv: fn(string) -> Option(string) = "(function(k)
  local v = os.getenv(k)
  if v then return { _tag = \"Some\", _0 = v } else return { _tag = \"None\" } end
end)";

extern modf: fn(float) -> (float, float) = "(function(x) return {math.modf(x)} end)";
extern frexp: fn(float) -> (float, float) = "(function(x) return {math.frexp(x)} end)";

extern tonumber: fn(string) -> Option(float) = "(function(s)
  local n = _G.tonumber(s)
  if n then return { _tag = \"Some\", _0 = n } else return { _tag = \"None\" } end
end)";

// --- I/O ---

extern read_file: fn(string) -> string = "(function(path)
  local f = _G.assert(io.open(path, \"r\"))
  local s = f:read(\"*a\")
  f:close()
  return s
end)";

extern read_stdin: fn() -> string = "(function() return io.read(\"*a\") end)";

// --- Algorithms ---

extern __heap_new: fn() -> mut Heap('a) = "(function() return {} end)";

extern __heap_push: fn(Heap('a), float, 'a) -> () = "(function(heap, priority, value)
  local item = {priority, value}
  heap[#heap + 1] = item
  local i = #heap
  while i > 1 do
  local p = math.floor(i / 2)
  if heap[i][1] < heap[p][1] then
      heap[i], heap[p] = heap[p], heap[i]
      i = p
  else
      break
  end
  end
  return {}
end)";

extern __heap_pop: fn(Heap('a)) -> (float, 'a) = "(function(heap)
  local n = #heap
  local top = heap[1]
  heap[1] = heap[n]
  heap[n] = nil
  n = n - 1
  local i = 1
  while true do
  local left = i * 2
  local right = left + 1
  local smallest = i
  if left <= n and heap[left][1] < heap[smallest][1] then smallest = left end
  if right <= n and heap[right][1] < heap[smallest][1] then smallest = right end
  if smallest == i then break end
  heap[i], heap[smallest] = heap[smallest], heap[i]
  i = smallest
  end
  return top
end)";

extern __heap_size: fn(Heap('a)) -> int = #[template] "#($1)";
extern __heap_is_empty: fn(Heap('a)) -> bool = #[template] "(#($1) == 0 and 1 or 0)";

impl Heap('a) {
  fn new() -> mut Self { __heap_new() }
  fn push(mut self, priority: float, value: 'a) -> () { __heap_push(self, priority, value) }
  fn pop(mut self) -> (float, 'a) { __heap_pop(self) }
  fn size(self) -> int { __heap_size(self) }
  fn is_empty(self) -> bool { __heap_is_empty(self) }
}

// --- Debugging ---

extern inspect: fn('a) -> string = "(function(v)
  local dq = string.char(34)
  local nl = string.char(10)
  local tab = string.char(9)
  local bs = string.char(92)
  local function ser(val)
  local t = type(val)
  if val == nil then
      return 'null'
  elseif t == 'string' then
      return dq .. val:gsub(bs, bs..bs):gsub(dq, bs..dq):gsub(nl, bs..'n'):gsub(tab, bs..'t') .. dq
  elseif t == 'number' or t == 'boolean' then
      return tostring(val)
  elseif t == 'table' then
      if val._tag ~= nil then
    local parts = {}
    for k, v2 in pairs(val) do
          if k ~= '_tag' then parts[#parts+1] = ser(v2) end
    end
    if #parts == 0 then return val._tag end
    if #parts == 1 then return val._tag .. '(' .. parts[1] .. ')' end
    return val._tag .. '(' .. table.concat(parts, ', ') .. ')'
      end
      local n = #val
      local size = 0
      for _ in pairs(val) do size = size + 1 end
      if size == n then
    local items = {}
    for i = 1, n do items[i] = ser(val[i]) end
    return '[' .. table.concat(items, ', ') .. ']'
      end
      local kvs = {}
      for k, v2 in pairs(val) do
    kvs[#kvs+1] = dq .. tostring(k) .. dq .. ': ' .. ser(v2)
      end
      return '{' .. table.concat(kvs, ', ') .. '}'
  else
      return dq .. '<' .. t .. '>' .. dq
  end
  end
  return ser(v)
end)";

fn json(value: 'a) -> string { inspect(value) }
